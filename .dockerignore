# --- Version control ---
.git/
.github/
.gitignore
.gitattributes
.gitmodules

# --- Rust build outputs (Nix rebuilds) ---
target/
**/target/
dist/
frontend/dist/
frontend/target/

# --- Local runtime data (mounted at runtime) ---
data/
local_uploads/
uploads/

# --- Nix build outputs ---
result
result-*

# --- Environment files ---
.env
.env.local
.env.*.local
!.env.example

# --- Docs (Nix copies only what's needed) ---
README.md
LICENSE
CONTRIBUTING.md
CODE_OF_CONDUCT.md
SECURITY.md
CHANGELOG.md

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- OS junk ---
.DS_Store
Thumbs.db

# --- Project extras ---
.cursorrules

# --- Docker artifacts ---
docker-compose*.yml
Dockerfile*